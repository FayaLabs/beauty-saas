{
  "name": "beauty-saas",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5180",
    "dev:published-sdk": "FAYZ_SDK_SOURCE=published vite --port 5180",
    "typecheck": "tsc -p tsconfig.local.json --noEmit",
    "build": "tsc -p tsconfig.local.json && FAYZ_SDK_SOURCE=local vite build",
    "build:published-sdk": "FAYZ_SDK_SOURCE=published tsc -p tsconfig.published.json && FAYZ_SDK_SOURCE=published vite build",
    "preview": "vite preview --port 5180",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:apply": "node scripts/db-apply.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.400.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "@supabase/supabase-js": "^2.49.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "@types/node": "^20.0.0",
    "drizzle-kit": "^0.28.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}