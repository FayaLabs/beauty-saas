{
  "name": "beauty-saas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5180",
    "dev:published-sdk": "FAYZ_SDK_SOURCE=published vite --port 5180",
    "typecheck": "tsc -p tsconfig.local.json --noEmit",
    "build": "tsc -p tsconfig.local.json && FAYZ_SDK_SOURCE=local vite build",
    "build:published-sdk": "FAYZ_SDK_SOURCE=published tsc -p tsconfig.published.json && FAYZ_SDK_SOURCE=published vite build",
    "preview": "vite preview --port 5180",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:apply": "node scripts/db-apply.mjs"
  },
  "dependencies": {
    "@fayz-ai/plugin-agenda": "^0.1.7",
    "@fayz-ai/plugin-crm": "^0.2.2",
    "@fayz-ai/plugin-dashboard": "^0.1.4",
    "@fayz-ai/plugin-financial": "^0.1.6",
    "@fayz-ai/plugin-forms": "^0.1.4",
    "@fayz-ai/plugin-inventory": "^0.1.5",
    "@fayz-ai/plugin-marketing": "^0.1.5",
    "@fayz-ai/plugin-reports": "^0.1.5",
    "@fayz-ai/plugin-tasks": "^0.1.5",
    "@fayz-ai/saas": "^0.5.0",
    "@fayz-ai/sdk": "^0.5.0",
    "@fayz-ai/ui": "^0.5.0",
    "lucide-react": "^0.577.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "drizzle-kit": "^0.28.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
