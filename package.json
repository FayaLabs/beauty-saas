{
  "name": "beauty-saas",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5180",
    "dev:published-sdk": "FAYZ_SDK_SOURCE=published vite --port 5180",
    "typecheck": "tsc -p tsconfig.local.json --noEmit",
    "build": "tsc -p tsconfig.local.json && FAYZ_SDK_SOURCE=local vite build",
    "build:published-sdk": "FAYZ_SDK_SOURCE=published tsc -p tsconfig.published.json && FAYZ_SDK_SOURCE=published vite build",
    "preview": "vite preview --port 5180",
    "migrate": "node ../../saas-core/scripts/migrate.mjs"
  },
  "dependencies": {
    "@fayz-ai/sdk": "^0.1.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "lucide-react": "^0.577.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "tailwindcss-animate": "*",
    "@supabase/supabase-js": "*"
  }
}