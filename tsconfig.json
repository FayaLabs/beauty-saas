{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@fayz-ai/sdk": ["../../fayz-sdk/packages/sdk/src"],
      "@fayz-ai/sdk/*": ["../../fayz-sdk/packages/sdk/src/*"],
      "@fayz-ai/core": ["../../fayz-sdk/packages/core/src"],
      "@fayz-ai/auth": ["../../fayz-sdk/packages/auth/src"],
      "@fayz-ai/ui": ["../../fayz-sdk/packages/ui/src"],
      "@fayz-ai/ui/*": ["../../fayz-sdk/packages/ui/src/*"],
      "@fayz-ai/saas": ["../../fayz-sdk/packages/saas/src"],
      "@fayz-ai/shop": ["../../fayz-sdk/packages/shop/src"],
      "@fayz-ai/db": ["../../fayz-sdk/packages/db/src"],
      "@fayz-ai/plugin-crm/*": ["../../fayz-sdk/plugins/plugin-crm/src/*"],
      "@fayz-ai/plugin-*": ["../../fayz-sdk/plugins/plugin-*/src"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
