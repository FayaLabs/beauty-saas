# Per-SaaS project database (plugin data: clients, appointments, products, etc.)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Core platform database (auth, tenants, billing, plugins, permissions)
# Falls back to VITE_SUPABASE_URL if not set (single-DB mode)

# Persona preset (optional). Set to "clinic" to boot a trimmed plugin set:
# dashboard + agenda (single-location) + financial (no bank reconciliation).
# Leave unset for the full salon configuration.
# VITE_BEAUTY_PRESET=clinic
