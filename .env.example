# Per-SaaS project database (plugin data: clients, appointments, products, etc.)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# TecnoSpeed bridge running locally or on the authorized Windows server.
VITE_TECNOSPEED_BRIDGE_URL=http://127.0.0.1:3001

# Enables the Google Calendar addon UI. Delivery runs server-side through hooks.
VITE_GOOGLE_CALENDAR_ENABLED=false

# Core platform database (auth, tenants, billing, plugins, permissions)
# Falls back to VITE_SUPABASE_URL if not set (single-DB mode)
